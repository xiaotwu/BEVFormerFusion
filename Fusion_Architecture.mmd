flowchart TD
      %% ============ RAW INPUTS ============
      subgraph INPUTS["Raw Sensor Inputs"]
          IMG["Multi-view Images<br/>(B, 6, 3, H, W)"]
          PTS["LiDAR Point Cloud<br/>(N, 4) — x,y,z,intensity"]
      end

      %% ============ CAMERA BRANCH ============
      subgraph CAM_BRANCH["Camera Feature Extraction"]
          GRID["GridMask Augmentation"]
          RESNET["ResNet-50 Backbone<br/>(frozen_stages=1)"]
          FPN["FPN Neck<br/>4 levels → 256ch each"]
          CAM_FEAT["Multi-scale Camera Features<br/>(B, 6, 256, H_i, W_i) × 4 levels"]
      end

      %% ============ LIDAR BRANCH ============
      subgraph LIDAR_BRANCH["PointPillars LiDAR BEV Extraction"]
          VOX["Voxelization<br/>voxel_size=[0.2, 0.2, 8]"]
          PILLAR["PillarFeatureNet<br/>4ch → 64ch"]
          SCATTER["PointPillarsScatter<br/>64ch, 512×512"]
          LIDAR_BEV["LiDAR Pseudo-Image<br/>(B, 64, 512, 512)"]
      end

      IMG --> GRID --> RESNET --> FPN --> CAM_FEAT
      PTS --> VOX --> PILLAR --> SCATTER --> LIDAR_BEV

      %% ============ ENCODER-SIDE LIDAR PROJECTION ============
      subgraph ENC_LIDAR_PROJ["Encoder-side LiDAR Projection"]
          ENC_INTERP["Bilinear Interpolate<br/>512×512 → 100×100"]
          ENC_CONV["Conv2d 1×1<br/>(lidar_encoder_proj)<br/>64ch → 256ch"]
          ENC_FLAT["Flatten + Permute<br/>(B, 10000, 256)"]
          LIDAR_TOK["lidar_bev_tokens"]
      end

      LIDAR_BEV --> ENC_INTERP --> ENC_CONV --> ENC_FLAT --> LIDAR_TOK

      %% ============ BEV QUERY INIT ============
      subgraph BEV_INIT["BEV Query Initialization"]
          BEV_EMB["Learnable BEV Embedding<br/>(10000, 256)"]
          CAN_BUS["CAN Bus MLP<br/>ego motion → 256ch"]
          BEV_POS["Learned Positional Encoding<br/>(B, 256, 100, 100)"]
          BEV_Q["BEV Queries<br/>(10000, B, 256)"]
      end

      BEV_EMB --> BEV_Q
      CAN_BUS -->|"+ add"| BEV_Q

      %% ============ TEMPORAL PREP ============
      subgraph TEMPORAL["Temporal Preparation"]
          PREV_BEV["Previous Frame BEV<br/>(from history cache)"]
          ROTATE["Rotate by ego motion angle"]
          SHIFT["Compute ego shift<br/>(Δx, Δy)"]
      end

      PREV_BEV --> ROTATE

      %% ============ ENCODER (4 LAYERS) ============
      subgraph ENCODER["BEVFormer Encoder — 4 × MM_BEVFormerLayer"]
          subgraph LAYER_N["Each Encoder Layer"]
              direction TB
              TSA["① Temporal Self-Attention<br/>BEV queries ↔ prev_bev"]
              NORM1["② LayerNorm"]

              subgraph DUAL_SCA["③ Dual Cross-Attention (Encoder-side Fusion)"]
                  direction LR
                  CAM_SCA["Camera SCA<br/>BEV queries attend to<br/>multi-scale image features<br/>via 3D→2D projection"]
                  LID_SCA["LiDAR SCA<br/>BEV queries attend to<br/>lidar_bev_tokens<br/>via deformable attn on BEV grid"]
              end

              BLEND["Learned Weighted Blend<br/>w = σ(logit)<br/>query = cam×w + lidar×(1−w)<br/><i>init: w=0.5, learned: w≈0.3</i>"]
              NORM2["④ LayerNorm"]
              FFN_E["⑤ FFN"]
              NORM3["⑥ LayerNorm"]
          end

          TSA --> NORM1 --> DUAL_SCA
          CAM_SCA --> BLEND
          LID_SCA --> BLEND
          BLEND --> NORM2 --> FFN_E --> NORM3
      end

      CAM_FEAT -->|"key/value"| CAM_SCA
      LIDAR_TOK -->|"key/value"| LID_SCA
      BEV_Q -->|"query"| TSA
      BEV_POS -->|"pos encoding"| LAYER_N
      ROTATE -->|"prev_bev"| TSA
      SHIFT -->|"shift offset"| ENCODER

      NORM3 --> ENC_OUT["Encoder Output: bev_embed<br/>(B, 10000, 256)<br/>Camera + Encoder-LiDAR fused"]

      %% ============ CLONE FOR VELOCITY ============
      ENC_OUT --> CLONE["Clone before decoder fusion"]
      CLONE --> BEV_CAM["bev_embed_cam<br/>(B, 10000, 256)<br/>Camera-dominant BEV<br/><i>preserved for velocity head</i>"]

      %% ============ DECODER-SIDE FUSION ============
      subgraph DEC_FUSION["Decoder-side LiDAR Fusion"]
          DEC_INTERP["Bilinear Interpolate<br/>512×512 → 100×100"]
          DEC_CONV["Conv2d 1×1<br/>(lidar_proj)<br/>64ch → 256ch"]
          DEC_FLAT["Flatten + Permute"]
          DEC_LN["Layer Norm"]
          DEC_SCALE["× 5.0 scaling<br/><i>match camera BEV magnitude</i>"]
          CONCAT["Concatenate<br/>[bev_embed ‖ lidar_tok]<br/>(B, 10000, 512)"]
          FUSE_LINEAR["Linear(512 → 256)<br/><i>init: identity on camera half,<br/>zeros on LiDAR half</i>"]
          FUSE_NORM["LayerNorm"]
      end

      LIDAR_BEV --> DEC_INTERP --> DEC_CONV --> DEC_FLAT --> DEC_LN --> DEC_SCALE
      ENC_OUT --> CONCAT
      DEC_SCALE --> CONCAT
      CONCAT --> FUSE_LINEAR --> FUSE_NORM

      FUSE_NORM --> FUSED_BEV["Fully Fused BEV<br/>(B, 10000, 256)<br/>Encoder-LiDAR + Decoder-LiDAR"]

      %% ============ DECODER ============
      subgraph DECODER["BEVFormer Decoder — 6 Layers"]
          OBJ_Q["Object Query Embedding<br/>(450, 512) → query + query_pos"]
          REF_PTS["Reference Points<br/>Linear(256→3) → sigmoid"]

          subgraph DEC_LAYER["Each Decoder Layer"]
              direction TB
              SELF_ATT["① Self-Attention<br/>queries ↔ queries"]
              DEC_NORM1["② LayerNorm"]
              CROSS_ATT["③ Cross-Attention<br/>queries attend to fused BEV<br/>via deformable attn"]
              DEC_NORM2["④ LayerNorm"]
              FFN_D["⑤ FFN"]
              DEC_NORM3["⑥ LayerNorm"]
          end

          DEC_HS["Decoder Hidden States<br/>(6, B, 450, 256)<br/>one per decoder layer"]
      end

      OBJ_Q --> SELF_ATT
      REF_PTS --> CROSS_ATT
      FUSED_BEV -->|"value"| CROSS_ATT
      SELF_ATT --> DEC_NORM1 --> CROSS_ATT --> DEC_NORM2 --> FFN_D --> DEC_NORM3
      DEC_NORM3 --> DEC_HS

      %% ============ PREDICTION HEADS ============
      subgraph HEADS["Prediction Heads (per decoder layer × 6)"]
          direction TB
          CLS_HEAD["Classification<br/>MLP → 10 classes<br/>(FocalLoss)"]
          BBOX_HEAD["BBox Regression<br/>MLP → 10-dim<br/>[x,y,log(w),log(l),z,log(h),<br/>sin,cos,0,0]<br/>(L1Loss, yaw/vel zeroed)"]

          subgraph YAW_HEAD["Yaw Prediction"]
              YAW_BIN["Yaw Bin Head<br/>MLP → 24 bins<br/>(CrossEntropyLoss)"]
              YAW_RES["Yaw Residual Head<br/>MLP → sin(Δ), cos(Δ)<br/>(L1Loss)"]
          end

          subgraph VEL_HEAD["Velocity Prediction"]
              VEL_XATTN["Cross-Attention<br/>decoder queries ↔ bev_embed_cam<br/><i>(camera-only BEV!)</i>"]
              VEL_MLP["MLP → (vx, vy)<br/>(L1Loss, pos queries only)"]
          end
      end

      DEC_HS --> CLS_HEAD
      DEC_HS --> BBOX_HEAD
      DEC_HS --> YAW_BIN
      DEC_HS --> YAW_RES
      DEC_HS -->|"query"| VEL_XATTN
      BEV_CAM -->|"key/value"| VEL_XATTN
      VEL_XATTN --> VEL_MLP

      %% ============ OUTPUTS ============
      subgraph OUTPUT["Final Outputs"]
          PRED["Per-object Predictions:<br/>• class scores<br/>• 3D bounding box (x,y,z,w,l,h)<br/>• yaw angle (bin + residual)<br/>• velocity (vx, vy)"]
      end

      CLS_HEAD --> PRED
      BBOX_HEAD --> PRED
      YAW_BIN --> PRED
      YAW_RES --> PRED
      VEL_MLP --> PRED

      %% ============ STYLING ============
      style INPUTS fill:#e1f5fe,stroke:#0288d1
      style CAM_BRANCH fill:#fff3e0,stroke:#f57c00
      style LIDAR_BRANCH fill:#e8f5e9,stroke:#388e3c
      style ENC_LIDAR_PROJ fill:#e8f5e9,stroke:#388e3c
      style BEV_INIT fill:#f3e5f5,stroke:#7b1fa2
      style TEMPORAL fill:#fce4ec,stroke:#c62828
      style ENCODER fill:#fff8e1,stroke:#f9a825
      style DUAL_SCA fill:#fffde7,stroke:#fbc02d
      style DEC_FUSION fill:#e8f5e9,stroke:#2e7d32
      style DECODER fill:#e3f2fd,stroke:#1565c0
      style DEC_LAYER fill:#e8eaf6,stroke:#283593
      style HEADS fill:#fce4ec,stroke:#ad1457
      style YAW_HEAD fill:#fff0f0,stroke:#c62828
      style VEL_HEAD fill:#f0fff0,stroke:#2e7d32
      style OUTPUT fill:#f5f5f5,stroke:#424242
      style BLEND fill:#ffecb3,stroke:#ff8f00,stroke-width:3px
      style CONCAT fill:#c8e6c9,stroke:#2e7d32,stroke-width:3px
      style BEV_CAM fill:#b2dfdb,stroke:#00695c,stroke-width:2px